function initDownload(url) {

    var x = 0;
    var y = 0;
    var width = 391;
    var height = 106;

    if (screen) {
        x = (screen.availWidth - width)/2;
        y = (screen.availHeight - height)/2;
    }

    var attributes = "width=" +width+ ",height=" +height+ ",screenX=" +x+ ",screenY=" +y+ ",top=" +y+ ",left=" +x+ "toolbar=no,location=no,directories=no,status=no,menubar=no,scrollbars=auto,resizeable=no";
    window.open(url,"_blank",attributes);
}
